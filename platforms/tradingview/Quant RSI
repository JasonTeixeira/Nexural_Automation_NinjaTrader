//@version=6
indicator("Quant RSI", shorttitle="QRSI", overlay=false, precision=2)

// =================== INPUT PARAMETERS ===================
// RSI Settings
var float gamma = input.float(0.7, "Filter Smoothing", minval=0.1, maxval=0.95, step=0.05)
var int shortLength = input.int(5, "Short-term Length", minval=2, maxval=20)
var int mediumLength = input.int(14, "Medium-term Length", minval=5, maxval=30)
var int longLength = input.int(21, "Long-term Length", minval=10, maxval=50)

// ATR Settings
var int atrPeriod = input.int(14, "ATR Period", minval=1)
var int atrSmoothPeriod = input.int(50, "ATR Smoothing Period", minval=1)

// Timeframe Settings - Updated to match requested timeframes
var string tf1 = input.string("5", "Timeframe 1", options=["1", "3", "5"])
var string tf2 = input.string("10", "Timeframe 2", options=["5", "10", "15"])
var string tf3 = input.string("15", "Timeframe 3", options=["15", "30"])
var string tf4 = input.string("30", "Timeframe 4", options=["30", "45", "60"])
var string tf5 = input.string("60", "Timeframe 5", options=["60", "120", "240"])

// ADX Settings
var int adxLength = input.int(14, "ADX Length", minval=1, maxval=50)

// Visual Settings
var color bullColor = input.color(color.new(#00BFB3, 0), "Bullish Color")
var color bearColor = input.color(color.new(#FF6B8B, 0), "Bearish Color")
var color neutralColor = input.color(color.new(#F5A300, 0), "Neutral Color")

