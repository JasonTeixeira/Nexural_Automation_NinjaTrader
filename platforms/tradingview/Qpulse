global_volatility_divergence_score := volatility_div_score
global_cvd_divergence := cvd_div
global_cvd_momentum := cvd_mom
global_vov_zscore := vov_z
global_vov_unstable := vov_unstable
global_market_stress := market_stress

// Divergence detection
[bullish_div_temp, bearish_div_temp, div_strength_temp] = detect_divergence(final_rsi)
bullish_div := bullish_div_temp
bearish_div := bearish_div_temp
div_strength := div_strength_temp

// ============================================================================
// VISUAL ELEMENTS
// ============================================================================

// Dynamic levels calculation
calculate_dynamic_levels() =>
    [regime, trend_strength, volatility] = detect_market_regime()
    
    base_ob = ((overbought - 50) * 2) * 2
    base_os = ((oversold - 50) * 2) * 2
    
    dynamic_ob = base_ob
    dynamic_os = base_os
    
    current_atr = cached_advanced_atr
    volatility_percentile = ta.percentrank(current_atr, 100)
    advanced_vol_adjustment = (volatility_percentile - 50) * 1.0
    
    trend_percentile = ta.percentrank(ta.ema(close, 20), 100)
    advanced_trend_adjustment = trend_percentile > 85.0 ? 40.0 : trend_percentile < 15.0 ? -40.0 : 0.0
    
    dynamic_ob := math.min(170.0, base_ob + advanced_vol_adjustment + advanced_trend_adjustment)
    dynamic_os := math.max(-170.0, base_os - advanced_vol_adjustment - advanced_trend_adjustment)
    
    [dynamic_ob, dynamic_os]

// Visual transformation functions
transform_rsi_for_display(rsi_value) =>
    if visual_mode == "Traditional"
        (rsi_value + 200) / 4
    else
        rsi_value

transform_level_for_display(level_value) =>
    if visual_mode == "Traditional"
        (level_value + 200) / 4
    else
        level_value

// Get display values
[dynamic_ob, dynamic_os] = calculate_dynamic_levels()
display_rsi = transform_rsi_for_display(final_rsi)
display_ob = transform_level_for_display(dynamic_ob)
display_os = transform_level_for_display(dynamic_os)
display_zero = transform_level_for_display(0)

// Calculate intensity for gradient
rsi_intensity = math.abs(final_rsi) / 200.0
gradient_opacity = 90 - int(rsi_intensity * 70)

// Main plots
histogram_color = final_rsi > 0 ? color.new(lime_color, gradient_opacity) : color.new(bright_red, gradient_opacity)
rsi_plot = plot(display_rsi, "QPulse Pro", color=histogram_color, linewidth=3, style=plot.style_histogram)
zero_plot = plot(display_zero, "ZERO LINE", color=white_color, linewidth=3)
ob_plot = plot(show_tech_levels ? display_ob : na, "Dynamic Overbought", color=color.new(bright_red, 60), linewidth=2)
os_plot = plot(show_tech_levels ? display_os : na, "Dynamic Oversold", color=color.new(lime_color, 60), linewidth=2)

// Zone fills
upper_fill_color = show_zones and show_tech_levels ? color.new(bright_red, 92) : color.new(#000000, 100)
lower_fill_color = show_zones and show_tech_levels ? color.new(lime_color, 92) : color.new(#000000, 100)

fill(rsi_plot, ob_plot, color=upper_fill_color, title="Overbought Zone")
fill(rsi_plot, os_plot, color=lower_fill_color, title="Oversold Zone")

// Key level lines
extreme_ob = visual_mode == "Traditional" ? 80.0 : transform_level_for_display(100.0)
extreme_os = visual_mode == "Traditional" ? 20.0 : transform_level_for_display(-100.0)

hline(show_tech_levels ? extreme_ob : na, "Extreme Overbought", color=color.new(bright_red, 70), linestyle=hline.style_dotted, linewidth=1)
hline(show_tech_levels ? extreme_os : na, "Extreme Oversold", color=color.new(lime_color, 70), linestyle=hline.style_dotted, linewidth=1)

// Divergence signals
if show_divergences and enable_divergence_engine
    if bearish_div[5]
        label.new(bar_index-5, display_rsi + 10, "▼", color=color.new(bright_red, 0), style=label.style_label_down, size=size.small, tooltip="Bearish Divergence\nStrength: " + str.tostring(div_strength, "#.1"))
    
    if bullish_div[5]
        label.new(bar_index-5, display_rsi - 10, "▲", color=color.new(lime_color, 0), style=label.style_label_up, size=size.small, tooltip="Bullish Divergence\nStrength: " + str.tostring(div_strength, "#.1"))

