// Volume Delta
calculate_volume_delta() =>
    if not enable_volume_delta
        [0.0, 0.0, false]
    else
        hl_range = high - low
        safe_range = math.max(hl_range, syminfo.mintick)
        close_position = (close - low) / safe_range
        delta = volume * (2 * close_position - 1)
        
        var float cumulative_delta = 0.0
        if ta.change(time("D")) != 0
            cumulative_delta := delta
        else
            cumulative_delta += delta
        
        lookback = 20
        price_trend = close > ta.highest(close[1], lookback)[1]
        delta_trend = cumulative_delta > ta.highest(cumulative_delta[1], lookback)[1]
        divergence = price_trend != delta_trend
        
        [delta, cumulative_delta, divergence]

// Volatility Signatures
detect_volatility_signature() =>
    if not enable_volatility_signatures
        ["NONE", 0.0, false]
    else
        atr_5 = ta.atr(5)
        atr_20 = ta.atr(20)
        compression_ratio = atr_5 / atr_20
        is_compressing = compression_ratio < 0.7
        was_compressed = ta.lowest(compression_ratio, 10) < 0.7
        current_expansion = compression_ratio > 1.2
        
        high_slope = (ta.highest(high, 20) - ta.highest(high, 20)[20]) / 20
        low_slope = (ta.lowest(low, 20) - ta.lowest(low, 20)[20]) / 20
        is_coiling = high_slope < 0 and low_slope > 0
        
        signature = is_compressing ? "COMPRESSION" : current_expansion and was_compressed ? "BREAKOUT" : is_coiling ? "COILING" : "NORMAL"
        confidence = is_compressing ? compression_ratio : current_expansion ? compression_ratio : 1.0
        breakout_imminent = was_compressed and compression_ratio > 0.65 and compression_ratio < 0.85
        
        [signature, confidence, breakout_imminent]

// VWAP Bands
calculate_vwap_bands() =>
    if not enable_vwap_bands
        [0.0, 0.0, 0.0, false]
    else
        vwap_val = ta.vwap(hlc3)
        squared_diff = math.pow(close - vwap_val, 2)
        variance = ta.sma(squared_diff * volume, 20) / ta.sma(volume, 20)
        stdev = math.sqrt(math.max(variance, 0))
        atr_mult = ta.atr(14) / ta.sma(ta.atr(14), 50)
        band_mult = 2.0 * atr_mult
        upper_band = vwap_val + (band_mult * stdev)
        lower_band = vwap_val - (band_mult * stdev)
        near_upper = high > upper_band * 0.98
        near_lower = low < lower_band * 1.02
        near_band = near_upper or near_lower
        [vwap_val, upper_band, lower_band, near_band]

// RVOL Detection
detect_volume_anomaly() =>
    if not enable_rvol_detection
        [1.0, false, "NORMAL"]
    else
        var vol_array = array.new_float(20, 0.0)
        if ta.change(time("D")) != 0
            array.shift(vol_array)
            array.push(vol_array, volume)
        
        avg_volume_this_time = array.avg(vol_array)
        safe_avg = math.max(avg_volume_this_time, ta.sma(volume, 20))
        rvol = volume / safe_avg
        
        price_range = high - low
        price_move = math.abs(close - open)
        price_confirms = price_move > price_range * 0.6
        
        is_spike = rvol > 2.5 and price_confirms
        is_extreme = rvol > 4.0 and price_confirms
        
        vol_pattern = is_extreme ? "EXTREME" :
                     is_spike ? "SPIKE" :
                     rvol > 1.5 ? "ELEVATED" :
                     rvol < 0.5 ? "DRY" : "NORMAL"
        
        [rvol, is_spike, vol_pattern]

// Divergence Engine
detect_divergence(rsi_value) =>
    if not enable_divergence_engine
        [false, false, 0.0]
    else
        pivot_lookback = 5
        
        price_pivot_high = ta.pivothigh(high, pivot_lookback, pivot_lookback)
        price_pivot_low = ta.pivotlow(low, pivot_lookback, pivot_lookback)
        rsi_pivot_high = ta.pivothigh(rsi_value, pivot_lookback, pivot_lookback)
        rsi_pivot_low = ta.pivotlow(rsi_value, pivot_lookback, pivot_lookback)
        
        var float last_price_high = na
        var float last_rsi_high = na
        var int last_high_bar = 0
        var float last_price_low = na
        var float last_rsi_low = na
        var int last_low_bar = 0
        
        if not na(price_pivot_high)
            last_price_high := high[pivot_lookback]
            last_rsi_high := rsi_value[pivot_lookback]
            last_high_bar := bar_index - pivot_lookback
        
        if not na(price_pivot_low)
            last_price_low := low[pivot_lookback]
            last_rsi_low := rsi_value[pivot_lookback]
            last_low_bar := bar_index - pivot_lookback
        
        bearish_div = false
        bullish_div = false
        div_strength = 0.0
        
        if not na(price_pivot_high) and not na(last_price_high) and bar_index - last_high_bar > pivot_lookback
            if high[pivot_lookback] > last_price_high and rsi_value[pivot_lookback] < last_rsi_high
                bearish_div := true
                div_strength := math.abs(rsi_value[pivot_lookback] - last_rsi_high)
        
        if not na(price_pivot_low) and not na(last_price_low) and bar_index - last_low_bar > pivot_lookback
            if low[pivot_lookback] < last_price_low and rsi_value[pivot_lookback] > last_rsi_low
                bullish_div := true
                div_strength := math.abs(rsi_value[pivot_lookback] - last_rsi_low)
        
        [bullish_div, bearish_div, div_strength]

