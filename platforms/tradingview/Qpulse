get_intermarket_data() =>
    if not enable_intermarket_divergence
        IntermarketData.new(0.0, 0.0, 0.0, 15.0)
    else
        market_type = detect_market_type()
        
        if market_type == "Futures"
            if str.contains(syminfo.ticker, "NQ")
                es_atr = request.security("ES1!", timeframe.period, ta.atr(14))
                rty_atr = request.security("RTY1!", timeframe.period, ta.atr(14))
                vix_val = request.security("VIX", timeframe.period, close)
                IntermarketData.new(es_atr, rty_atr, 0.0, vix_val)
            else if str.contains(syminfo.ticker, "ES")
                nq_atr = request.security("NQ1!", timeframe.period, ta.atr(14))
                rty_atr = request.security("RTY1!", timeframe.period, ta.atr(14))
                vix_val = request.security("VIX", timeframe.period, close)
                IntermarketData.new(nq_atr, rty_atr, 0.0, vix_val)
            else
                // Default futures
                IntermarketData.new(ta.atr(14), ta.atr(14), ta.atr(14), 15.0)
        else
            // Default for equities/crypto
            IntermarketData.new(ta.atr(14), ta.atr(14), ta.atr(14), 15.0)

