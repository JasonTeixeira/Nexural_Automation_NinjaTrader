// Intermarket Divergence
calculate_intermarket_divergence(atr1, atr2, atr3, vix) =>
    if not enable_intermarket_divergence
        [false, 0.0, "NORMAL"]
    else
        current_atr = cached_advanced_atr
        
        // Use pre-fetched intermarket data
        current_zscore = (current_atr - ta.sma(current_atr, 20)) / ta.stdev(current_atr, 20)
        zscore1 = (atr1 - ta.sma(atr1, 20)) / ta.stdev(atr1, 20)
        zscore2 = (atr2 - ta.sma(atr2, 20)) / ta.stdev(atr2, 20)
        
        avg_other_zscores = (zscore1 + zscore2) / 2
        divergence_score = math.abs(current_zscore - avg_other_zscores)
        
        significant_divergence = divergence_score > 1.5
        isolated_stress = current_zscore > 1.0 and avg_other_zscores < 0.5
        
        vix_spike = ta.roc(vix, 1) > 10
        vix_elevated = vix > ta.sma(vix, 20) * 1.2
        
        stress_level = isolated_stress ? "ISOLATED" :
                      significant_divergence and vix_spike ? "SYSTEMIC" :
                      significant_divergence ? "DIVERGENT" :
                      vix_elevated ? "ELEVATED" : "NORMAL"
        
        breakout_signal = significant_divergence and (isolated_stress or vix_spike)
        
        [breakout_signal, divergence_score, stress_level]

// CVD Proxy
calculate_cvd_proxy() =>
    if not enable_cvd_proxy
        [false, 0.0, 0.0]
    else
        high_close_ratio = (close - low) / math.max(high - low, 0.0001)
        buy_pressure = volume * high_close_ratio
        sell_pressure = volume * (1 - high_close_ratio)
        net_delta = buy_pressure - sell_pressure
        
        var float cvd = 0.0
        if ta.change(time("D")) != 0
            cvd := net_delta
        else
            cvd += net_delta
        
        cvd_fast = ta.ema(cvd, 20)
        cvd_slow = ta.ema(cvd, 50)
        cvd_momentum = (cvd_fast - cvd_slow) / math.abs(cvd_slow + 0.0001)
        
        lookback_bars = 20
        price_higher = close > ta.highest(close[1], lookback_bars)
        price_lower = close < ta.lowest(close[1], lookback_bars)
        cvd_higher = cvd > ta.highest(cvd[1], lookback_bars)
        cvd_lower = cvd < ta.lowest(cvd[1], lookback_bars)
        
        bullish_cvd_div = price_lower and not cvd_lower
        bearish_cvd_div = price_higher and not cvd_higher
        
        divergence_detected = bearish_cvd_div or bullish_cvd_div
        
        [divergence_detected, cvd, cvd_momentum]

// Direct VoV
calculate_direct_vov() =>
    if not enable_direct_vov
        [0.0, false, false]
    else
        // Optimized array management
        if barstate.isconfirmed
            array.push(vov_array, ta.atr(14))
            if array.size(vov_array) > 20
                array.shift(vov_array)
        
        if array.size(vov_array) < 20
            [0.0, false, false]
        else
            atr_mean = array.avg(vov_array)
            atr_stdev = array.stdev(vov_array)
            vov = atr_stdev / math.max(atr_mean, 0.0001)
            
            vov_ma = ta.sma(vov, 50)
            vov_stdev_hist = ta.stdev(vov, 50)
            vov_zscore = (vov - vov_ma) / math.max(vov_stdev_hist, 0.0001)
            
            unstable_regime = vov_zscore > 1.5
            stabilizing_regime = vov_zscore < -1.0 and ta.change(vov_zscore) > 0
            
            vov_expanding = ta.change(vov) > 0 and ta.change(vov[1]) > 0
            vol_volume_corr = ta.correlation(ta.atr(14), volume, 20)
            decorrelation = vol_volume_corr < 0.2 and ta.sma(vol_volume_corr, 20) > 0.5
            
            vov_breakout_signal = (unstable_regime and vov_expanding) or (stabilizing_regime and decorrelation)
            
            [vov_zscore, unstable_regime, vov_breakout_signal]

// ============================================================================
// CORE RSI CALCULATIONS
// ============================================================================

price_change = ta.change(src)
gains = math.max(price_change, 0)
losses = math.abs(math.min(price_change, 0))

// Volume-Weighted RSI
calculate_vwrsi() =>
    volume_sma = ta.sma(volume, 20)
    volume_factor = volume / volume_sma
    adjusted_volume_factor = math.pow(volume_factor, vw_sensitivity)
    
    vw_gains = gains * adjusted_volume_factor
    vw_losses = losses * adjusted_volume_factor
    
    smoothed_vw_gains = ta.ema(vw_gains, length)
    smoothed_vw_losses = ta.ema(vw_losses, length)
    
    safe_vw_gains = math.max(smoothed_vw_gains, 0.0001)
    safe_vw_losses = math.max(smoothed_vw_losses, 0.0001)
    
    vw_rs = safe_vw_gains / safe_vw_losses
    vwrsi = vw_rs > 0 ? 100.0 - (100.0 / (1.0 + vw_rs)) : 50.0
    
    vwrsi_centered = (vwrsi - 50.0) * 4.0
    math.max(-200.0, math.min(200.0, vwrsi_centered))

// Adaptive EMA
adaptive_ema(src, len) =>
    safe_len = na(len) or len <= 0 ? length : int(len)
    safe_len := int(math.max(2, math.min(50, safe_len)))
    
    alpha = 2.0 / (float(safe_len) + 1.0)
    
    var float ema_val = na
    if na(ema_val) or bar_index < safe_len
        ema_val := na(src) ? 0.0 : src
    else
        ema_val := alpha * src + (1.0 - alpha) * ema_val
    
    ema_val

// ATR-Adaptive RSI
calculate_advanced_atr_rsi() =>
    current_atr = cached_advanced_atr
    avg_atr = cached_advanced_atr_avg
    
    advanced_volatility_ratio = avg_atr > 0 ? current_atr / avg_atr : 1.0
    adjusted_advanced_ratio = math.pow(math.max(0.1, math.min(5.0, advanced_volatility_ratio)), atr_sensitivity)
    
    length_multiplier = 2.0 - math.min(1.8, adjusted_advanced_ratio)
    advanced_adaptive_length = int(math.round(float(length) * length_multiplier))
    advanced_adaptive_length := int(math.max(2, math.min(50, advanced_adaptive_length)))
    
    adaptive_gains = adaptive_ema(gains, advanced_adaptive_length)
    adaptive_losses = adaptive_ema(losses, advanced_adaptive_length)
    
    safe_adaptive_gains = math.max(adaptive_gains, 0.0001)
    safe_adaptive_losses = math.max(adaptive_losses, 0.0001)
    
    advanced_atr_rs = safe_adaptive_gains / safe_adaptive_losses
    advanced_atr_rsi = advanced_atr_rs > 0 ? 100.0 - (100.0 / (1.0 + advanced_atr_rs)) : 50.0
    
    advanced_atr_rsi_centered = (advanced_atr_rsi - 50.0) * 4.0
    math.max(-200.0, math.min(200.0, advanced_atr_rsi_centered))

// Market Regime Detection
detect_market_regime() =>
    current_atr = cached_advanced_atr
    avg_atr = cached_advanced_atr_avg
    trend_strength = math.abs(ta.sma(close, 20) - ta.sma(close, 50)) / current_atr
    volatility_regime = current_atr / avg_atr
    
    regime = trend_strength > 1.0 ? "TRENDING" : volatility_regime > 1.2 ? "VOLATILE" : "RANGING"
    [regime, trend_strength, volatility_regime]

// Hybrid Weighting
calculate_advanced_hybrid_weights() =>
    volume_strength = volume / ta.sma(volume, 20)
    current_atr = cached_advanced_atr
    avg_atr = cached_advanced_atr_avg
    advanced_volatility_regime = current_atr / avg_atr
    [regime, trend_strength, market_volatility] = detect_market_regime()
    
    volume_weight = 0.5
    atr_weight = 0.5
    
    if hybrid_mode == "Volume-Favored"
        volume_weight := 0.7
        atr_weight := 0.3
    else if hybrid_mode == "ATR-Favored"
        volume_weight := 0.3
        atr_weight := 0.7
    else if hybrid_mode == "Balanced"
        volume_weight := 0.5
        atr_weight := 0.5
    else // Auto mode
        if global_cvd_divergence and volume_strength > 1.5
            volume_weight := 0.85
            atr_weight := 0.15
        else if global_vov_unstable and advanced_volatility_regime > 1.4
            volume_weight := 0.20
            atr_weight := 0.80
        else if global_intermarket_divergence and regime == "VOLATILE"
            volume_weight := 0.45
            atr_weight := 0.55
        else if volume_strength > 1.8 and regime == "RANGING"
            volume_weight := 0.75
            atr_weight := 0.25
        else if advanced_volatility_regime > 1.4 and regime == "VOLATILE"
            volume_weight := 0.25
            atr_weight := 0.75
        else if regime == "TRENDING"
            volume_weight := 0.35
            atr_weight := 0.65
        else
            volume_weight := 0.5
            atr_weight := 0.5
    
    [volume_weight, atr_weight]

// Final RSI Calculation
calculate_final_rsi() =>
    if enable_hybrid
        vwrsi_value = calculate_vwrsi()
        advanced_atr_rsi_value = calculate_advanced_atr_rsi()
        [vol_weight, atr_weight] = calculate_advanced_hybrid_weights()
        
        hybrid_result = (vwrsi_value * vol_weight + advanced_atr_rsi_value * atr_weight)
        math.max(-200, math.min(200, hybrid_result))
    else
        smoothed_gains = ta.ema(gains, length)
        smoothed_losses = ta.ema(losses, length)
        safe_gains = math.max(smoothed_gains, 0.0001)
        safe_losses = math.max(smoothed_losses, 0.0001)
        rs = safe_gains / safe_losses
        rsi_traditional = rs > 0 ? 100.0 - (100.0 / (1.0 + rs)) : 50.0
        traditional_centered = (rsi_traditional - 50.0) * 4.0
        math.max(-200.0, math.min(200.0, traditional_centered))

