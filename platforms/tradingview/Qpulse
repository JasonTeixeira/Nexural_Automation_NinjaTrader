calculate_volume_baseline() =>
    // Check if we need to update
    needs_update = bar_index - last_volume_baseline_bar > 100 or ta.change(time("D")) != 0
    baseline = volume_baseline
    
    if needs_update
        baseline := ta.percentile_nearest_rank(volume, 100, 50)
    
    [baseline, needs_update]

calculate_volume_normalization() =>
    if not enable_volume_norm
        [1.0, 60.0]
    else
        // Get current volume baseline
        [baseline, needs_update] = calculate_volume_baseline()
        
        // Calculate volume ratio
        safe_baseline = na(baseline) or baseline <= 0 ? ta.sma(volume, 100) : baseline
        vol_ratio = volume / math.max(safe_baseline, 1.0)
        vol_ratio_capped = math.min(vol_ratio, 2.0)  // Cap at 2x to prevent over-amplification
        
        // Calculate participation factor with configurable power
        participation = math.pow(vol_ratio_capped, volume_norm_power)
        
        // Statistical significance thresholds
        threshold = 60.0
        if enable_stat_significance
            vol_percentile = ta.percentrank(volume, 100)
            threshold := vol_percentile < low_vol_threshold ? 150.0 : vol_percentile < med_vol_threshold ? 100.0 : 60.0
        
        [participation, threshold]

