// MAIN CALCULATIONS
// ============================================================================

// Update ATR cache
[new_atr, new_avg, atr_updated] = calculate_advanced_atr_cached()
if atr_updated
    cached_advanced_atr := new_atr
    cached_advanced_atr_avg := new_avg
    last_atr_calc_bar := bar_index

// Get intermarket data
imd = get_intermarket_data()

// Calculate raw RSI
raw_final_rsi = calculate_final_rsi()

// VOLUME NORMALIZATION - Apply to final RSI
[volume_participation, signal_threshold] = calculate_volume_normalization()
global_volume_participation := volume_participation
global_signal_threshold := signal_threshold

// Update volume baseline if needed
[baseline, needs_update] = calculate_volume_baseline()
if needs_update
    volume_baseline := baseline
    last_volume_baseline_bar := bar_index

// Scale the RSI by volume participation
volume_adjusted_rsi = raw_final_rsi * volume_participation

// Apply statistical significance filter
dampening_factor = math.abs(volume_adjusted_rsi) < signal_threshold ? 0.3 : 1.0
final_rsi = volume_adjusted_rsi * dampening_factor

// Calculate all detection values
[delta_calc, cum_delta_calc, delta_div_calc] = calculate_volume_delta()
[rvol_calc, rvol_spike_calc, vol_pattern_calc] = detect_volume_anomaly()
[vol_sig_calc, vol_sig_conf_calc, breakout_imminent_calc] = detect_volatility_signature()
[vwap_calc, vwap_upper_calc, vwap_lower_calc, near_band_calc] = calculate_vwap_bands()

// Calculate quant-grade values
[intermarket_div, volatility_div_score, market_stress] = calculate_intermarket_divergence(imd.atr1, imd.atr2, imd.atr3, imd.vix)
[cvd_div, cvd_value, cvd_mom] = calculate_cvd_proxy()
[vov_z, vov_unstable, vov_breakout] = calculate_direct_vov()

// Update globals
global_delta := delta_calc
global_cum_delta := cum_delta_calc
global_rvol := rvol_calc
global_vol_pattern := vol_pattern_calc
global_vol_signature := vol_sig_calc
