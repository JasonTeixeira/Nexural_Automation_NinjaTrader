// Heatmap color function
getHeatmapColorAndOpacity(rsi_value, intensity) =>
    base_color = rsi_value > 0 ? lime_color : bright_red
    opacity = 90 - int(intensity * 70)
    [base_color, opacity]

// Clear old heatmap
if barstate.isconfirmed
    while array.size(heatmap_boxes) > 0
        b = array.pop(heatmap_boxes)
        box.delete(b)

// Draw heatmap
if show_heatmap and barstate.islast
    step = heatmap_lookback > 100 ? 2 : 1
    
    for i = 0 to heatmap_lookback - 1 by step
        if i < bar_index
            historical_rsi = nz(final_rsi[i], 0)
            
            smoothed_value = historical_rsi
            if heatmap_smoothing > 1
                sum = 0.0
                count = 0
                for j = -heatmap_smoothing to heatmap_smoothing
                    idx = i + j
                    if idx >= 0 and idx < bar_index
                        sum += nz(final_rsi[idx], 0)
                        count += 1
                smoothed_value := sum / math.max(count, 1)
            
            intensity = math.abs(smoothed_value) / 200.0
            [heat_color, opacity] = getHeatmapColorAndOpacity(smoothed_value, intensity)
            
            if smoothed_value > 0
                heat_box_top = box.new(left=bar_index - i - 1, top=200 + heatmap_height, right=bar_index - i, bottom=200, bgcolor=color.new(heat_color, opacity), border_width=0)
                array.push(heatmap_boxes, heat_box_top)
            else if smoothed_value < 0
                heat_box_bottom = box.new(left=bar_index - i - 1, top=-200, right=bar_index - i, bottom=-200 - heatmap_height, bgcolor=color.new(heat_color, opacity), border_width=0)
                array.push(heatmap_boxes, heat_box_bottom)

