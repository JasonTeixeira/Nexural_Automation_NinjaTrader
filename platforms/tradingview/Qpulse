// Custom EMA function
custom_ema(src, len) =>
    safe_len = na(len) or len <= 0 ? 14.0 : len
    safe_len := math.max(2.0, math.min(50.0, safe_len))
    safe_src = na(src) ? close : src
    alpha = 2.0 / (safe_len + 1.0)
    
    var float ema_val = na
    if na(ema_val) or bar_index < 10
        ema_val := safe_src
    else
        ema_val := alpha * safe_src + (1.0 - alpha) * ema_val
    
    na(ema_val) ? safe_src : ema_val

// Advanced ATR calculation with caching
calculate_advanced_atr_cached() =>
    // Check if we need to recalculate
    needs_update = bar_index != last_atr_calc_bar
    current_atr = cached_advanced_atr
    current_avg = cached_advanced_atr_avg
    
    if needs_update
        if not enable_advanced_atr
            current_atr := ta.atr(14)
            current_avg := ta.sma(ta.atr(14), 50)
        else
            // Layer 1: Adaptive Period
            returns = ta.change(close) / math.max(close[1], 0.0001)
            abs_returns = math.abs(returns)
            returns_std = ta.stdev(returns, 20)
            mean_abs_returns = ta.sma(abs_returns, 20)
            safe_returns_std = na(returns_std) or returns_std <= 0 ? 0.02 : returns_std
            safe_mean_abs_returns = na(mean_abs_returns) or mean_abs_returns <= 0 ? 0.01 : mean_abs_returns
            market_efficiency = safe_returns_std / safe_mean_abs_returns
            base_period = 14.0
            efficiency_factor = math.max(0.5, math.min(2.0, market_efficiency))
            optimal_period = math.round(base_period * (0.5 + efficiency_factor * adaptive_strength))
            final_period = math.max(5.0, math.min(30.0, optimal_period))
            safe_optimal_period = float(na(final_period) ? 14.0 : final_period)
            
            // Layer 2: Garman-Klass
            safe_high = math.max(high, close)
            safe_low = math.min(low, close)
            safe_open = na(open) ? close : open
            log_hl = math.log(math.max(safe_high / safe_low, 1.0001))
            log_co = math.log(math.max(close / safe_open, 1.0001))
            gk_vol = 0.5 * log_hl * log_hl - (2 * math.log(2) - 1) * log_co * log_co
            gk_atr = math.sqrt(math.max(0, gk_vol)) * close
            traditional_range = safe_high - safe_low
            gk_result = na(gk_atr) or gk_atr <= 0 ? traditional_range : math.max(gk_atr, traditional_range)
            
            // Layer 3: Volume-Weighted
            tr1 = high - low
            tr2 = math.abs(high - close[1])
            tr3 = math.abs(low - close[1])
            true_range = math.max(tr1, math.max(tr2, tr3))
            volume_sma = ta.sma(volume, 20)
            safe_volume_sma = na(volume_sma) or volume_sma <= 0 ? volume : volume_sma
            volume_factor = volume / safe_volume_sma
            safe_volume_integration = math.max(0.1, math.min(3.0, volume_integration))
            adjusted_volume_factor = math.pow(math.max(0.1, volume_factor), safe_volume_integration)
            vw_true_range = true_range * math.max(0.1, math.min(5.0, adjusted_volume_factor))
            
            // Combine layers
            combined_volatility = math.max(gk_result, vw_true_range)
            enhanced_atr = custom_ema(combined_volatility, safe_optimal_period)
            
            // Final result
            current_atr := enhanced_atr * math.max(0.1, math.min(3.0, advanced_sensitivity))
            current_avg := custom_ema(current_atr, 50.0)
    
    [current_atr, current_avg, needs_update]

