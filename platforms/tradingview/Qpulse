// Auto-detect market type
detect_market_type() =>
    ticker = syminfo.ticker
    if futures_mode != "Auto-Detect"
        futures_mode
    else if str.contains(ticker, "ES") or str.contains(ticker, "NQ") or str.contains(ticker, "RTY") or 
       str.contains(ticker, "CL") or str.contains(ticker, "GC") or str.contains(ticker, "6") or str.contains(ticker, "ZB")
        "Futures"
    else if str.contains(ticker, "BTC") or str.contains(ticker, "ETH") or str.contains(ticker, "CRYPTO")
        "Crypto"
    else
        "Equities"

// Safe string conversion
safe_str(value, format, fallback) =>
    if na(value)
        fallback
    else
        str.tostring(value, format)

// Safe number with fallback
safe_num(value, fallback) =>
    if na(value)
        fallback
    else
        value

